// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// CMS Compliance Data Models
model CMSRecord {
  id          String   @id @default(cuid())
  recordId    String   @unique
  coveredRecipientId String
  coveredRecipientName String
  coveredRecipientType String
  teachingHospitalId String?
  teachingHospitalName String?
  teachingHospitalCcn String?
  coveredRecipientNpi String?
  physicianProfileId String?
  physicianFirstName String?
  physicianMiddleName String?
  physicianLastName String?
  physicianNameSuffix String?
  recipientPrimaryBusinessStreetAddressLine1 String?
  recipientPrimaryBusinessStreetAddressLine2 String?
  recipientCity String?
  recipientState String?
  recipientZipCode String?
  recipientCountry String?
  recipientProvince String?
  recipientPostalCode String?
  physicianPrimaryType String?
  physicianSpecialty String?
  physicianLicenseStateCode1 String?
  physicianLicenseStateCode2 String?
  physicianLicenseStateCode3 String?
  physicianLicenseStateCode4 String?
  physicianLicenseStateCode5 String?
  submittingApplicableManufacturerOrApplicableGpoName String?
  applicableManufacturerOrApplicableGpoMakingPaymentId String?
  applicableManufacturerOrApplicableGpoMakingPaymentName String?
  applicableManufacturerOrApplicableGpoMakingPaymentState String?
  applicableManufacturerOrApplicableGpoMakingPaymentCountry String?
  totalAmountOfPaymentUsdollars Float
  dateOfPayment String?
  numberOfPaymentsIncludedInTotalAmount String?
  formOfPaymentOrTransferOfValue String?
  natureOfPaymentOrTransferOfValue String?
  cityOfTravel String?
  stateOfTravel String?
  countryOfTravel String?
  physicianOwnershipIndicator String?
  thirdPartyPaymentRecipientIndicator String?
  nameOfThirdPartyEntityReceivingPaymentOrTransferOfValue String?
  charityIndicator String?
  thirdPartyEqualsCoveredRecipientIndicator String?
  contextualInformation String?
  delayInPublicationIndicator String?
  disputeStatusForPublication String?
  productIndicator String?
  relatedProductIndicator String?
  changeType String? @default("N")
  sourceSystem String?
  nameOfAssociatedCoveredDrugOrBiological1 String?
  nameOfAssociatedCoveredDrugOrBiological2 String?
  nameOfAssociatedCoveredDrugOrBiological3 String?
  nameOfAssociatedCoveredDrugOrBiological4 String?
  nameOfAssociatedCoveredDrugOrBiological5 String?
  ndcOfAssociatedCoveredDrugOrBiological1 String?
  ndcOfAssociatedCoveredDrugOrBiological2 String?
  ndcOfAssociatedCoveredDrugOrBiological3 String?
  ndcOfAssociatedCoveredDrugOrBiological4 String?
  ndcOfAssociatedCoveredDrugOrBiological5 String?
  nameOfAssociatedCoveredDeviceOrMedicalSupply1 String?
  nameOfAssociatedCoveredDeviceOrMedicalSupply2 String?
  nameOfAssociatedCoveredDeviceOrMedicalSupply3 String?
  nameOfAssociatedCoveredDeviceOrMedicalSupply4 String?
  nameOfAssociatedCoveredDeviceOrMedicalSupply5 String?
  programYear String?
  paymentPublicationDate String?
  
  // Processing fields
  isReportable Boolean @default(false)
  humanDecision String? // 'approve', 'reject', 'pending'
  humanReason String?
  decisionTime DateTime?
  finalReportable Boolean?
  appliedRules Json?
  reason String?

  // COM-TRANSP-001 transparency fields
  cmsReportCategory String? // general | research | ownership
  paymentCurrency String? @default("USD")
  exchangeRate Float? @default(1)
  reportingCurrencyValue Float?
  consentForDisclosure Boolean?
  disclosureType String? // individual | aggregate
  aggregateStatus String? // not_applicable | pending | reportable | non_reportable
  recipientAnnualAggregate Float?
  disputeWorkflowStatus String? @default("none") // none | under_review | disputed | corrected | resolved
  disputeOpenedAt DateTime?
  disputeResolvedAt DateTime?
  disputeNotes String?
  
  // Audit fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  reviewSessionId String?
  reviewSession ReviewSession? @relation(fields: [reviewSessionId], references: [id])
  spendEventId String? @unique
  spendEvent SpendEvent? @relation(fields: [spendEventId], references: [id])
  
  @@map("cms_records")
}

model CompanyRule {
  id          String   @id @default(cuid())
  name        String
  description String
  ruleType    String   // 'threshold', 'exclusion', 'inclusion', 'validation'
  conditions  Json     // Rule conditions and logic
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("company_rules")
}

/** Per-jurisdiction reporting thresholds (CMS Sunshine, Loi Bertrand, etc.). */
model JurisdictionRule {
  id                   String   @id @default(cuid())
  jurisdictionCode     String
  jurisdictionName     String
  perPaymentMin        Float?
  aggregateAnnualMin   Float?
  currency             String   @default("USD")
  fmvTolerancePercent  Float    @default(10)
  regulatoryBasis      String?
  effectiveDate        String
  expirationDate       String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([jurisdictionCode, effectiveDate])
  @@index([jurisdictionCode, isActive])
  @@map("jurisdiction_rules")
}

/** FMV benchmarks synced from CLM / fmv_engine connector. */
model FmvRate {
  id             String   @id @default(cuid())
  natureKey      String
  natureLabel    String
  specialtyTier  String   @default("default")
  rateUsd        Float
  unit           String   @default("event")
  sourceKey      String   @default("fmv_engine")
  effectiveDate  String
  expirationDate String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([natureKey, specialtyTier, effectiveDate])
  @@index([isActive, natureKey])
  @@map("fmv_rates")
}

/** Specialty tier multipliers applied to base FMV rates. */
model FmvSpecialtyTier {
  id           String   @id @default(cuid())
  tierKey      String   @unique
  multiplier   Float    @default(1)
  displayLabel String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("fmv_specialty_tiers")
}

model ReviewSession {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  filename    String
  originalFilename String
  filePath    String?  // Path to stored CSV file
  fileSize    Int?     // File size in bytes
  fileHash    String?  // SHA-256 hash for integrity verification
  uploadTime  DateTime @default(now())
  totalRecords Int
  processedRecords Int @default(0)
  reportableCount Int @default(0)
  nonReportableCount Int @default(0)
  errorCount Int @default(0)
  status      String   @default("pending_review") // 'pending_review', 'in_review', 'completed'
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  records     CMSRecord[]
  
  @@map("review_sessions")
}

model DataUpload {
  id          String   @id @default(cuid())
  filename    String
  originalFilename String
  filePath    String?  // Path to stored CSV file
  fileSize    Int
  fileHash    String?  // SHA-256 hash for integrity verification
  totalRecords Int
  processedRecords Int @default(0)
  reportableCount Int @default(0)
  nonReportableCount Int @default(0)
  errorCount Int @default(0)
  status      String   @default("processing") // 'processing', 'completed', 'failed'
  validationSummary Json?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("data_uploads")
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // 'create', 'update', 'delete', 'approve', 'reject'
  entityType  String   // 'record', 'rule', 'session'
  entityId    String
  oldValues   Json?
  newValues   Json?
  reason      String?
  performedBy String?
  performedAt DateTime @default(now())
  
  @@map("audit_logs")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  passwordHash String?
  role        String   // 'admin', 'compliance_officer', 'data_analyst', 'executive'
  isActive    Boolean  @default(true)
  lastLogin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("users")
}

model StoredFile {
  id          String   @id @default(cuid())
  filename    String
  originalFilename String
  filePath    String   @unique
  fileSize    Int
  fileHash    String   @unique
  mimeType    String   @default("text/csv")
  uploadTime  DateTime @default(now())
  lastAccessed DateTime?
  accessCount Int      @default(0)
  isActive    Boolean  @default(true)
  retentionDate DateTime? // When file should be deleted
  uploadedBy  String?
  sessionId   String?  // Link to review session
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("stored_files")
}

// ---------------------------------------------------------------------------
// Lineage & CMS PUF submission models (Jan 2025 data dictionary alignment)
// ---------------------------------------------------------------------------

model DataSource {
  id               String   @id @default(cuid())
  sourceKey        String   @unique
  sourceName       String
  sourceCategory   String   // financial | crm | travel | clinical | vendor | mdm | upload
  connectorVersion String   @default("1.0")
  isActive         Boolean  @default(true)
  config           Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  transactions SourceTransaction[]
  spendEvents  SpendEvent[]

  @@map("data_sources")
}

model HcpMaster {
  id                   String   @id @default(cuid())
  masterKey            String   @unique
  npi                  String?
  cmsProfileId         String?
  firstName            String?
  middleName           String?
  lastName             String?
  nameSuffix           String?
  fullName             String?
  specialty            String?
  primaryType          String?
  coveredRecipientType String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  state                String?
  zipCode              String?
  country              String?
  province             String?
  postalCode           String?
  licenseStateCodes    Json?
  teachingHospitalId   String?
  teachingHospitalName String?
  teachingHospitalCcn  String?
  matchStatus          String   @default("pending")
  sourceCrosswalk      Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  spendEvents SpendEvent[]

  @@index([npi])
  @@index([cmsProfileId])
  @@map("hcp_master")
}

model SourceTransaction {
  id                    String   @id @default(cuid())
  dataSourceId          String
  dataSource            DataSource @relation(fields: [dataSourceId], references: [id])
  externalTransactionId String?
  reviewSessionId       String?
  rowNumber             Int?
  rawPayload            Json
  payloadHash           String
  ingestedAt            DateTime @default(now())
  status                String   @default("received")

  spendEvents SpendEvent[]

  @@unique([dataSourceId, payloadHash])
  @@index([reviewSessionId])
  @@map("source_transactions")
}

model SpendEvent {
  id                    String   @id @default(cuid())
  dataSourceId          String
  dataSource            DataSource @relation(fields: [dataSourceId], references: [id])
  sourceTransactionId   String
  sourceTransaction     SourceTransaction @relation(fields: [sourceTransactionId], references: [id])
  hcpMasterId           String?
  hcpMaster             HcpMaster? @relation(fields: [hcpMasterId], references: [id])
  dedupKey              String
  crossSourceDedupKey   String?
  dedupClusterId        String?
  dedupReviewStatus     String   @default("none")
  isPrimaryLine         Boolean  @default(true)
  amountUsd             Float
  paymentCurrency       String   @default("USD")
  exchangeRate          Float    @default(1)
  paymentDate           String?
  programYear           String?
  natureOfPayment       String?
  formOfPayment         String?
  cmsCategory           String   @default("general")
  sourceSystem          String
  normalizationVersion  String   @default("1.0")
  rulesEngineVersion    String?
  ruleInputSnapshot     Json?
  status                String   @default("normalized")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  cmsRecord     CMSRecord?
  generalLine   CmsGeneralPaymentLine?
  researchLine  CmsResearchPaymentLine?
  ownershipLine CmsOwnershipPaymentLine?

  @@index([dedupKey])
  @@index([crossSourceDedupKey])
  @@index([dedupClusterId])
  @@index([dedupReviewStatus])
  @@index([programYear])
  @@map("spend_events")
}

model CmsSubmissionBatch {
  id              String   @id @default(cuid())
  batchKey        String   @unique
  programYear     String
  fileType        String   // general | research | ownership | mixed
  status          String   @default("draft")
  recordCount     Int      @default(0)
  attestedAt      DateTime?
  attestedBy      String?
  exportHash      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  generalLines   CmsGeneralPaymentLine[]
  researchLines  CmsResearchPaymentLine[]
  ownershipLines CmsOwnershipPaymentLine[]

  @@map("cms_submission_batches")
}

model CmsGeneralPaymentLine {
  id                 String   @id @default(cuid())
  spendEventId       String   @unique
  spendEvent         SpendEvent @relation(fields: [spendEventId], references: [id])
  submissionBatchId  String?
  submissionBatch    CmsSubmissionBatch? @relation(fields: [submissionBatchId], references: [id])
  pufFields          Json
  recordId           String
  programYear        String
  coveredRecipientNpi String?
  totalAmount        Float
  dateOfPayment      String?
  natureOfPayment    String?
  disputeStatus      String?
  changeType         String   @default("N")
  isReportable       Boolean  @default(false)
  rulesEngineVersion String?
  ruleInputSnapshot  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([programYear])
  @@index([isReportable])
  @@map("cms_general_payment_lines")
}

model CmsResearchPaymentLine {
  id                 String   @id @default(cuid())
  spendEventId       String   @unique
  spendEvent         SpendEvent @relation(fields: [spendEventId], references: [id])
  submissionBatchId  String?
  submissionBatch    CmsSubmissionBatch? @relation(fields: [submissionBatchId], references: [id])
  pufFields          Json
  recordId           String
  programYear        String
  totalAmount        Float
  nameOfStudy        String?
  clinicalTrialsId   String?
  preclinicalIndicator String?
  isReportable       Boolean  @default(false)
  rulesEngineVersion String?
  ruleInputSnapshot  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([programYear])
  @@map("cms_research_payment_lines")
}

model CmsOwnershipPaymentLine {
  id                 String   @id @default(cuid())
  spendEventId       String   @unique
  spendEvent         SpendEvent @relation(fields: [spendEventId], references: [id])
  submissionBatchId  String?
  submissionBatch    CmsSubmissionBatch? @relation(fields: [submissionBatchId], references: [id])
  pufFields          Json
  recordId           String
  programYear        String
  physicianNpi       String?
  totalAmountInvested Float?
  valueOfInterest    Float?
  isReportable       Boolean  @default(false)
  rulesEngineVersion String?
  ruleInputSnapshot  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([programYear])
  @@map("cms_ownership_payment_lines")
}