# Application configuration (copy to .env.local)

# PostgreSQL (required — Sprint B cutover from SQLite)
# CMSKNF docker compose maps Postgres to host port 5433 (5432 is often in use).
DATABASE_URL=postgresql://cms_user:cms_password@localhost:5433/cms_compliance

# Demo mode: enables NPPES offline fallback for seeded NPIs (1234567890, 9876543210).
# Set to false in production so only live NPPES API results are accepted.
DEMO_MODE=true

# Pilot profile — enables auth, NPPES block at ingest, disables demo NPPES fallback.
# PILOT_MODE=true
# AUTH_ENABLED=true
# NPPES_INGEST_POLICY=block
# JWT_SECRET=change-me-in-production
# CRON_SECRET=change-me-in-production

# NPPES verification at ingest: off | warn | block (block prevents OPS export)
# Defaults to block when PILOT_MODE=true
NPPES_INGEST_POLICY=warn

# CMS NPPES Read API v2.1 (optional override — no auth required)
# NPPES_API_BASE_URL=https://npiregistry.cms.hhs.gov/api/

# Public API rate limits (requests per window per IP). Set max to 0 to disable.
# HCP_PORTAL_RATE_LIMIT_WINDOW_MS=900000
# HCP_PORTAL_RATE_LIMIT_MAX_REQUESTS=30
# DISCLOSURE_RATE_LIMIT_WINDOW_MS=900000
# DISCLOSURE_RATE_LIMIT_MAX_REQUESTS=60

# Secret for cron / scheduled jobs (POST /api/jobs/aggregate, FMV sync)
# CRON_SECRET=change-me-in-production

# Optional override for FMV variance tolerance (percent). Defaults to jurisdiction_rules.fmv_tolerance_percent.
# FMV_TOLERANCE_PERCENT=10

# Auth — defaults to on in production / PILOT_MODE
# AUTH_ENABLED=false

# CMS Open Payments API
# OPEN_PAYMENTS_API_BASE_URL=https://openpaymentsdata.cms.gov/api/1

# Veeva OpenData MDM enrichment (optional)
# VEEVA_OPEN_DATA_BASE_URL=https://opendata.veevanetwork.com/api
# VEEVA_OPEN_DATA_API_KEY=

# CMS dataset storage — metadata in database/manifest.json
# CMS_DATASET_MANIFEST_PATH=../database/manifest.json
# CMS_DATASET_STORAGE=auto
# CMS_DATASET_DESKTOP_SYNC_ROOT=/Users/you/Google Drive/My Drive/CMSKNF/cms-open-payments
# GDRIVE_DATASET_FOLDER_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
