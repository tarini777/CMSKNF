# CMS Compliance Platform - Environment Configuration
# Copy this file to .env.local and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://cms_user:secure_password@localhost:5432/cms_compliance"

# Alternative: SQLite for development
# DATABASE_URL="file:./dev.db"

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email Service Configuration
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="noreply@cms-compliance.com"

# Email Service Provider (gmail, outlook, smtp)
EMAIL_SERVICE="gmail"

# SMTP Configuration (if using custom SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"

# Email Recipients for Notifications
ALERT_EMAIL_RECIPIENTS="admin@company.com,compliance@company.com"
DAILY_SUMMARY_RECIPIENTS="compliance@company.com,analytics@company.com"

# =============================================================================
# EXTERNAL API CONFIGURATION
# =============================================================================

# CMS FHIR API Configuration (Patient Access, Provider Access, Payer-to-Payer)
CMS_FHIR_BASE_URL="https://api.cms.gov/fhir/v1"
CMS_FHIR_CLIENT_ID="your-cms-fhir-client-id"
CMS_FHIR_CLIENT_SECRET="your-cms-fhir-client-secret"
CMS_FHIR_SCOPE="system/Patient.read system/Coverage.read system/ExplanationOfBenefit.read system/Task.read system/Practitioner.read"
CMS_FHIR_TOKEN_URL="https://api.cms.gov/oauth2/token"
CMS_FHIR_API_VERSION="4.0.1"
CMS_API_TIMEOUT="10000"

# Legacy CMS Open Payments API (for backward compatibility)
CMS_API_KEY="your-cms-api-key"
CMS_API_URL="https://openpaymentsdata.cms.gov/api/v1"

# PubMed API Configuration (NCBI E-utilities)
PUBMED_EUTILS_BASE_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils"
PUBMED_ESEARCH_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi"
PUBMED_EFETCH_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi"
PUBMED_ELINK_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/elink.fcgi"
PUBMED_ESUMMARY_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi"
PUBMED_EINFO_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/einfo.fcgi"
PUBMED_ESPELL_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/espell.fcgi"
PUBMED_EGQUERY_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/egquery.fcgi"
PUBMED_API_TIMEOUT="15000"
PUBMED_MAX_RESULTS="100"
PUBMED_RATE_LIMIT="3"

# ClinicalTrials.gov API Configuration
CLINICALTRIALS_API_BASE_URL="https://clinicaltrials.gov/api/v2"
CLINICALTRIALS_CLASSIC_API_URL="https://clinicaltrials.gov/api/query"
CLINICALTRIALS_PYTHON_API_URL="https://clinicaltrials.gov/api/query/study_fields"
CLINICALTRIALS_API_TIMEOUT="20000"
CLINICALTRIALS_MAX_STUDIES="100"
CLINICALTRIALS_RATE_LIMIT="100"

# CMS Open Payments API Configuration
OPEN_PAYMENTS_API_BASE_URL="https://openpaymentsdata.cms.gov/api/1"
OPEN_PAYMENTS_API_TIMEOUT="30000"
OPEN_PAYMENTS_MAX_RESULTS="1000"
OPEN_PAYMENTS_RATE_LIMIT="10"
OPEN_PAYMENTS_DEFAULT_LIMIT="50"

# API Rate Limiting
API_RATE_LIMIT="100"
API_RETRY_ATTEMPTS="3"

# =============================================================================
# ML/AI CONFIGURATION
# =============================================================================

# ML Model Configuration
ML_MODEL_PATH="./models/"
ML_CONFIDENCE_THRESHOLD="0.8"
ML_ANOMALY_THRESHOLD="0.7"

# Model Training Configuration
ML_TRAINING_ENABLED="true"
ML_RETRAIN_FREQUENCY="weekly"
ML_FEATURE_ENGINEERING_ENABLED="true"

# ML Performance Monitoring
ML_PERFORMANCE_MONITORING="true"
ML_ACCURACY_THRESHOLD="0.9"

# =============================================================================
# MONITORING & ALERTING
# =============================================================================

# System Monitoring
MONITORING_ENABLED="true"
HEALTH_CHECK_INTERVAL="60000"
PERFORMANCE_MONITORING_ENABLED="true"

# Alert Configuration
ALERT_SEVERITY_LEVELS="low,medium,high,critical"
ALERT_ESCALATION_TIME="24"
ALERT_SLACK_WEBHOOK="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"

# API Monitoring
API_MONITORING_ENABLED="true"
API_HEALTH_CHECK_INTERVAL="60000"
API_TIMEOUT_THRESHOLD="5000"

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Set to "true" in production Docker; "false" skips login in local dev
AUTH_ENABLED="false"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# Session Configuration
SESSION_SECRET="your-session-secret-key-change-this-in-production"
SESSION_MAX_AGE="86400"

# Encryption Keys
ENCRYPTION_KEY="your-32-character-encryption-key-here"
DATA_ENCRYPTION_ENABLED="true"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,https://your-domain.com"
CORS_CREDENTIALS="true"

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# File Upload Limits
MAX_FILE_SIZE="104857600"  # 100MB in bytes
MAX_FILES_PER_UPLOAD="10"
ALLOWED_FILE_TYPES=".csv,.xlsx,.xls"

# File Storage
FILE_STORAGE_PATH="./uploads/"
FILE_CLEANUP_ENABLED="true"
FILE_RETENTION_DAYS="30"

# =============================================================================
# REPORTING CONFIGURATION
# =============================================================================

# PDF Report Configuration
PDF_REPORT_ENABLED="true"
PDF_TEMPLATE_PATH="./templates/"
PDF_OUTPUT_PATH="./reports/"

# Report Generation
REPORT_GENERATION_ENABLED="true"
REPORT_SCHEDULING_ENABLED="true"
REPORT_RETENTION_DAYS="90"

# =============================================================================
# BUSINESS RULES CONFIGURATION
# =============================================================================

# Payment Thresholds
MIN_REPORTABLE_AMOUNT="10.00"
HIGH_VALUE_THRESHOLD="50000.00"
CRITICAL_VALUE_THRESHOLD="100000.00"

# Review Thresholds
AUTO_APPROVAL_LIMIT="1000.00"
MANUAL_REVIEW_REQUIRED="10000.00"
EXECUTIVE_APPROVAL_REQUIRED="50000.00"

# Compliance Rules
MAX_PAYMENTS_PER_RECIPIENT_MONTH="10"
MAX_CONSULTING_FEE_ANNUAL="25000.00"
MAX_GIFT_ANNUAL="10.00"

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Processing Configuration
BATCH_SIZE="1000"
PROCESSING_TIMEOUT="300"
MAX_CONCURRENT_UPLOADS="5"

# Caching Configuration
CACHE_ENABLED="true"
CACHE_TTL="3600"
REDIS_URL="redis://localhost:6379"

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Debug Configuration
DEBUG_ENABLED="true"
LOG_LEVEL="info"
VERBOSE_LOGGING="false"

# Development Tools
HOT_RELOAD="true"
SOURCE_MAPS="true"
ANALYZE_BUNDLE="false"

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Production Settings (uncomment for production)
# NODE_ENV="production"
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Production Security
# HTTPS_ONLY="true"
# SECURE_COOKIES="true"
# TRUST_PROXY="true"

# Production Performance
# COMPRESSION_ENABLED="true"
# CDN_URL="https://cdn.your-domain.com"
# STATIC_ASSETS_CACHING="true"

# =============================================================================
# INTEGRATION CONFIGURATION
# =============================================================================

# Webhook Configuration
WEBHOOK_ENABLED="true"
WEBHOOK_SECRET="your-webhook-secret"
WEBHOOK_TIMEOUT="5000"

# Third-party Integrations
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
MICROSOFT_TEAMS_WEBHOOK="https://your-teams-webhook-url"

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED="true"
BACKUP_FREQUENCY="daily"
BACKUP_RETENTION_DAYS="30"
BACKUP_STORAGE_PATH="./backups/"

# Disaster Recovery
DR_ENABLED="true"
DR_REPLICATION_ENABLED="true"
DR_FAILOVER_ENABLED="true"

# =============================================================================
# COMPLIANCE & AUDIT
# =============================================================================

# Audit Configuration
AUDIT_LOGGING_ENABLED="true"
AUDIT_LOG_RETENTION_DAYS="2555"  # 7 years
AUDIT_LOG_PATH="./logs/audit/"

# Compliance Configuration
COMPLIANCE_MODE="strict"
REGULATORY_UPDATES_ENABLED="true"
COMPLIANCE_REPORTING_ENABLED="true"

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Feature Toggles
FEATURE_ML_ANOMALY_DETECTION="true"
FEATURE_EXTERNAL_API_INTEGRATION="true"
FEATURE_REAL_TIME_MONITORING="true"
FEATURE_EMAIL_NOTIFICATIONS="true"
FEATURE_PDF_REPORTS="true"
FEATURE_ADVANCED_ANALYTICS="true"

# Experimental Features
FEATURE_EXPERIMENTAL_ML_MODELS="false"
FEATURE_BETA_INTEGRATIONS="false"
FEATURE_ADVANCED_VISUALIZATIONS="true"

# =============================================================================
# CUSTOMIZATION
# =============================================================================

# Branding Configuration
COMPANY_NAME="Your Company Name"
COMPANY_LOGO_URL="/logo.png"
BRAND_COLOR_PRIMARY="#22C55E"
BRAND_COLOR_SECONDARY="#3B82F6"

# Custom Configuration
CUSTOM_RULES_ENABLED="true"
CUSTOM_REPORTS_ENABLED="true"
CUSTOM_DASHBOARD_ENABLED="true"

# =============================================================================
# NOTES
# =============================================================================

# 1. Never commit actual secrets to version control
# 2. Use environment-specific .env files (.env.local, .env.production)
# 3. Rotate secrets regularly in production
# 4. Use a secrets management service for production deployments
# 5. Test all configurations in staging before production deployment

# For production deployment, consider using:
# - AWS Secrets Manager
# - Azure Key Vault
# - HashiCorp Vault
# - Kubernetes Secrets
